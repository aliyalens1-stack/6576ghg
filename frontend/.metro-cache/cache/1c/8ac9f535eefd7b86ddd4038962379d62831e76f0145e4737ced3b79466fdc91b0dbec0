     \"acceptance\": {\n        \"title\": \"Принятие условий\",\n        \"body\": \"Используя приложение, вы подтверждаете, что прочитали и согласны с настоящими Условиями. Если не согласны — не используйте сервис.\"\n      },\n      \"service_description\": {\n        \"title\": \"Описание сервиса\",\n        \"body\": \"AutoService — это маркетплейс, соединяющий клиентов и автосервисы. Мы не выполняем ремонт сами — мастера работают как независимые подрядчики.\"\n      },\n      \"accounts\": {\n        \"title\": \"Аккаунты\",\n        \"body\": \"Для использования сервиса нужно создать аккаунт. Вы отвечаете за сохранность пароля. Один человек — один аккаунт.\"\n      },\n      \"user_obligations\": {\n        \"title\": \"Обязанности пользователя\",\n        \"body\": \"Не использовать сервис в незаконных целях. Не оскорблять мастеров и других клиентов. Предоставлять достоверную информацию.\"\n      },\n      \"payments\": {\n        \"title\": \"Оплата\",\n        \"body\": \"Платежи проходят через защищённый эскроу. Комиссия платформы — 10% от стоимости заказа, удерживается с мастера.\"\n      },\n      \"cancellation\": {\n        \"title\": \"Отмена заказа\",\n        \"body\": \"До приезда мастера — отмена бесплатна. После прибытия — может удерживаться плата за выезд согласно тарифу мастера.\"\n      },\n      \"liability\": {\n        \"title\": \"Ответственность\",\n        \"body\": \"Качество работ обеспечивает мастер. Платформа не несёт прямой ответственности за результат, но помогает разрешить спор.\"\n      },\n      \"changes\": {\n        \"title\": \"Изменения условий\",\n        \"body\": \"Мы можем менять Условия. О существенных изменениях уведомим за 30 дней push-уведомлением и email.\"\n      },\n      \"governing_law\": {\n        \"title\": \"Применимое право\",\n        \"body\": \"Споры разрешаются по законодательству страны регистрации сервиса (Германия для DE-региона, Украина для UA-региона).\"\n      },\n      \"contact\": {\n        \"title\": \"Контакты\",\n        \"body\": \"Вопросы по Условиям: legal@autoservice.com\"\n      }\n    }\n  },\n  \"privacy\": {\n    \"title\": \"Политика конфиденциальности\",\n    \"last_updated\": \"Последнее обновление\",\n    \"intro\": \"Мы серьёзно относимся к вашим данным. Эта политика объясняет, что мы собираем, как используем и какие у вас права.\",\n    \"sections\": {\n      \"data_we_collect\": {\n        \"title\": \"Какие данные мы собираем\",\n        \"body\": \"Контактные данные (email, телефон), геолокацию (только когда приложение открыто), историю заказов, отзывы.\"\n      },\n      \"how_we_use\": {\n        \"title\": \"Как используем\",\n        \"body\": \"Для подбора мастеров рядом, расчёта цены, обработки платежей, связи по заказу и улучшения сервиса.\"\n      },\n      \"sharing\": {\n        \"title\": \"Передача данных\",\n        \"body\": \"Мастеру передаётся только минимум: ваше имя, локация (для встречи) и описание проблемы. Контакт открывается после принятия заявки.\"\n      },\n      \"storage\": {\n        \"title\": \"Хранение\",\n        \"body\": \"Данные хранятся в защищённых дата-центрах ЕС (GDPR-совместимо). История заказов — 3 года, после чего обезличивается.\"\n      },\n      \"rights\": {\n        \"title\": \"Ваши права\",\n        \"body\": \"Вы можете запросить копию данных, исправление, удаление аккаунта. Напишите на privacy@autoservice.com.\"\n      },\n      \"cookies\": {\n        \"title\": \"Cookies и трекинг\",\n        \"body\": \"Используем технические cookies для работы сервиса. Аналитика — анонимная, без продажи данных рекламодателям.\"\n      },\n      \"children\": {\n        \"title\": \"Дети\",\n        \"body\": \"Сервис не предназначен для лиц младше 18 лет. Мы не собираем данные о детях.\"\n      },\n      \"changes\": {\n        \"title\": \"Изменения политики\",\n        \"body\": \"О существенных изменениях уведомим заранее push и email.\"\n      },\n      \"contact\": {\n        \"title\": \"Ко